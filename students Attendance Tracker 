import tkinter as tk
from tkinter import ttk, messagebox
import csv
from datetime import datetime
import os

FILE_NAME = "attendance.csv"

# Create file if not exists
if not os.path.exists(FILE_NAME):
    with open(FILE_NAME, "w", newline="") as file:
        writer = csv.writer(file)
        writer.writerow(["Date", "Roll No", "Student Name", "Status"])


# Save Attendance
def save_attendance():
    roll = roll_entry.get()
    name = name_entry.get()
    status = status_var.get()

    if roll == "" or name == "":
        messagebox.showerror("Error", "Please fill all fields")
        return

    date = datetime.now().strftime("%d-%m-%Y")

    with open(FILE_NAME, "a", newline="") as file:
        writer = csv.writer(file)
        writer.writerow([date, roll, name, status])

    messagebox.showinfo("Success", "Attendance Saved Successfully")

    roll_entry.delete(0, tk.END)
    name_entry.delete(0, tk.END)


# View Attendance
def view_attendance():
    for item in tree.get_children():
        tree.delete(item)

    with open(FILE_NAME, "r") as file:
        reader = csv.reader(file)
        next(reader)

        for row in reader:
            tree.insert("", tk.END, values=row)


# Search Student
def search_student():
    roll = search_entry.get()

    for item in tree.get_children():
        tree.delete(item)

    with open(FILE_NAME, "r") as file:
        reader = csv.reader(file)
        next(reader)

        for row in reader:
            if row[1] == roll:
                tree.insert("", tk.END, values=row)


# Attendance Summary
def attendance_summary():
    total = 0
    present = 0
    absent = 0

    with open(FILE_NAME, "r") as file:
        reader = csv.reader(file)
        next(reader)

        for row in reader:
            total += 1
            if row[3] == "Present":
                present += 1
            else:
                absent += 1

    messagebox.showinfo(
        "Attendance Summary",
        f"Total Records : {total}\n\nPresent : {present}\nAbsent : {absent}"
    )


# Main Window
root = tk.Tk()
root.title("Student Attendance Tracker")
root.geometry("900x600")
root.configure(bg="#f4f4f4")

title = tk.Label(
    root,
    text="STUDENT ATTENDANCE TRACKER",
    font=("Arial", 20, "bold"),
    bg="#f4f4f4",
    fg="navy"
)
title.pack(pady=10)

# Input Frame
frame = tk.Frame(root, bg="#f4f4f4")
frame.pack(pady=10)

tk.Label(frame, text="Roll No", font=("Arial", 12),
         bg="#f4f4f4").grid(row=0, column=0, padx=10, pady=5)

roll_entry = tk.Entry(frame, width=25)
roll_entry.grid(row=0, column=1)

tk.Label(frame, text="Student Name", font=("Arial", 12),
         bg="#f4f4f4").grid(row=1, column=0, padx=10, pady=5)

name_entry = tk.Entry(frame, width=25)
name_entry.grid(row=1, column=1)

tk.Label(frame, text="Attendance", font=("Arial", 12),
         bg="#f4f4f4").grid(row=2, column=0, padx=10, pady=5)

status_var = tk.StringVar()
status_var.set("Present")

attendance_menu = ttk.Combobox(
    frame,
    textvariable=status_var,
    values=["Present", "Absent"],
    state="readonly",
    width=22
)
attendance_menu.grid(row=2, column=1)

# Buttons
button_frame = tk.Frame(root, bg="#f4f4f4")
button_frame.pack(pady=10)

tk.Button(
    button_frame,
    text="Save Attendance",
    command=save_attendance,
    bg="green",
    fg="white",
    width=18
).grid(row=0, column=0, padx=10)

tk.Button(
    button_frame,
    text="View Attendance",
    command=view_attendance,
    bg="blue",
    fg="white",
    width=18
).grid(row=0, column=1, padx=10)

tk.Button(
    button_frame,
    text="Attendance Summary",
    command=attendance_summary,
    bg="orange",
    fg="white",
    width=18
).grid(row=0, column=2, padx=10)

# Search Frame
search_frame = tk.Frame(root, bg="#f4f4f4")
search_frame.pack(pady=10)

tk.Label(search_frame, text="Search Roll No",
         font=("Arial", 12), bg="#f4f4f4").grid(row=0, column=0)

search_entry = tk.Entry(search_frame)
search_entry.grid(row=0, column=1, padx=10)

tk.Button(
    search_frame,
    text="Search",
    command=search_student,
    bg="purple",
    fg="white"
).grid(row=0, column=2)

# Table
columns = ("Date", "Roll No", "Student Name", "Status")

tree = ttk.Treeview(root, columns=columns, show="headings", height=15)

for col in columns:
    tree.heading(col, text=col)
    tree.column(col, width=180)

tree.pack(pady=20)

root.mainloop()